rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 1. DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 2. HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // 3. ENTITY VALIDATIONS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt'])
        && data.keys().size() == 3
        && data.email is string && data.email.size() <= 200
        && data.role in ['admin', 'staff']
        && data.createdAt == request.time;
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'createdAt'])
        && data.name is string && data.name.size() <= 200
        && (data.get('phone', '') is string)
        && (data.get('email', '') is string)
        && (data.get('address', '') is string)
        && (data.get('idImageUrls', []) is list)
        && data.createdAt == request.time;
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'shortDescription'])
        && data.title is string && data.title.size() <= 100
        && data.shortDescription is string && data.shortDescription.size() <= 500;
    }

    function isValidPolicy(data) {
      return data.keys().hasAll(['clientId', 'serviceId', 'policyNumber', 'status', 'createdAt'])
        && data.clientId is string
        && data.serviceId is string
        && data.policyNumber is string && data.policyNumber.size() <= 50
        && data.status in ['active', 'pending', 'expired', 'cancelled']
        && data.createdAt == request.time;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['policyId', 'amount', 'status', 'date', 'createdAt'])
        && data.policyId is string
        && data.amount is number && data.amount > 0
        && data.status in ['paid', 'pending', 'overdue']
        && data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // 4. COLLECTION MATCHES
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isAdmin() && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidClient(incoming());
      allow update: if isSignedIn() && isValidClient(incoming());
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true; // Publicly readable for the catalog
      allow write: if isAdmin() && isValidService(incoming());
    }

    match /policies/{policyId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidPolicy(incoming());
      allow update: if isSignedIn() && isValidPolicy(incoming());
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidPayment(incoming());
      allow update: if isSignedIn() && isValidPayment(incoming());
      allow delete: if isAdmin();
    }
  }
}
